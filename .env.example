# DALA Analytics Portal — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Flask
SECRET_KEY=change-me-to-a-random-string-in-production
PORT=5000

# Email delivery (SMTP)
# Gmail: enable 2FA + create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-gmail@gmail.com

# WhatsApp delivery (Twilio)
# Sign up at twilio.com → create WhatsApp sandbox or Business account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Maps (enables store geocoding + interactive map in Trends)
# Get key at console.cloud.google.com → APIs & Services → Geocoding API + Maps JS API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Sheets / Drive
# Place service account JSON at google_credentials.json (already present)
# OR run: python setup_oauth.py  to create google_token.json via OAuth2
# Target Drive folder ID stored in google_folder_id.txt

# Database (optional — defaults to local dala_data.db)
# Set DATABASE_URL if you want PostgreSQL on Railway
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
